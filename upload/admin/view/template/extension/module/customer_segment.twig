var banner_row = 0;
function addBannerImage(image, thumb, link) {
    image = image || '';
    thumb = thumb || '{{ placeholder }}';
    link = link || '';
    var html  = '<tr id="banner-row' + banner_row + '">';
    html += '  <td class="text-center"><a href="" id="thumb-banner' + banner_row + '" data-toggle="image" class="img-thumbnail"><img src="' + thumb + '" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="banner_data[' + banner_row + '][image]" value="' + image + '" id="input-banner' + banner_row + '" /></td>';
    html += '  <td class="text-left"><input type="text" name="banner_data[' + banner_row + '][link]" value="' + link + '" class="form-control" /></td>';
    html += '  <td class="text-left"><button type="button" onclick="$(\'#banner-row' + banner_row  + '\').remove();" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
                    html += '  <td class="text-left"><button type="button" onclick="$(\'#banner-row' + banner_row  + '\').remove();" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
    html += '</tr>';
    $('#banner-image-table tbody').append(html);
    banner_row++;
}

function openPromoModal(promo_id) {
    $('#form-promo')[0].reset();
    $('#promo-group-list, #promo-category-list, #promo-product-list').empty();
    $('#banner-image-table tbody').empty();
    $('#promo-notification-title').val('');
    $('#promo-notification-body').val('');
    $('#promo-id').val(promo_id || '');
    banner_row = 0;

    if (promo_id) {
        $.ajax({ 
            url: 'index.php?route=extension/module/customer_segment/getPromotion&user_token={{ user_token }}&promotion_id=' + promo_id, 
            dataType: 'json', 
            success: function(p) {
                if (p) {
                    $('#promo-title').val(p.title);
                    $('#promo-desc').val(p.description);
                    $('#promo-type').val(p.type);
                    $('#promo-visual-type').val(p.visual_type || 'none');
                    $('#promo-status').val(p.status);
                    $('#promo-scope').val(p.scope);
                    $('#promo-discount-value').val(p.discount_value);
                    $('#promo-discount-type').val(p.discount_type);
                    $('#promo-code').val(p.code);
                    $('#promo-date-start').val(p.date_start);
                    $('#promo-date-end').val(p.date_end);
                    $('#promo-notification-title').val(p.notification_title);
                    $('#promo-notification-body').val(p.notification_body);
                    
                    if (p.group_ids) { 
                        $.each(p.group_ids, function(id, name) { 
                            $('#promo-group-list').append('<div id="promo-group-list-item' + id + '"><i class="fa fa-minus-circle"></i> ' + name + '<input type="hidden" name="group_ids[]" value="' + id + '" /></div>'); 
                        }); 
                    }

                    if (p.banner_data) {
                        try {
                            var bdata = JSON.parse(p.banner_data);
                            $.each(bdata, function(k, v) {
                                addBannerImage(v.image, v.thumb || v.image, v.link);
                            });
                        } catch(e) {
                            console.log('Error parsing banner_data:', e);
                        }
                    }

                    if (p.category_ids) {
                        $.ajax({
                            url: 'index.php?route=extension/module/customer_segment/getCategoryInfo&user_token={{ user_token }}&ids=' + p.category_ids,
                            dataType: 'json',
                            success: function(cJson) {
                                for(var j=0; j<cJson.length; j++) {
                                    $('#promo-category-list').append('<div id="promo-category-list-item' + cJson[j].category_id + '"><i class="fa fa-minus-circle"></i> ' + cJson[j].name + '<input type="hidden" name="category_ids[]" value="' + cJson[j].category_id + '" /></div>');
                                }
                            }
                        });
                    }
                    
                    if (p.product_ids) {
                        $.ajax({
                            url: 'index.php?route=extension/module/customer_segment/getProductInfo&user_token={{ user_token }}&ids=' + p.product_ids,
                            dataType: 'json',
                            success: function(pJson) {
                                for(var j=0; j<pJson.length; j++) {
                                    $('#promo-product-list').append('<div id="promo-product' + pJson[j].product_id + '"><i class="fa fa-minus-circle"></i> ' + pJson[j].name + '<input type="hidden" name="selected_product[]" value="' + pJson[j].product_id + '" /></div>');
                                }
                            }
                        });
                    }
                    togglePromoType();
                    togglePromoScope();
                }
            }
        });
    } else {
        togglePromoType();
        togglePromoScope();
    }
    $('#modal-promo').modal('show');
}

function togglePromoType() {
    var val = $('#promo-type').val();
    $('#promo-discount-settings').hide();
    $('#promo-manual-code-settings').hide();
    
    if (val == 'cart_discount') {
        $('#promo-discount-settings').show();
    } else if (val == 'manual_code') {
        $('#promo-discount-settings').show();
        $('#promo-manual-code-settings').show();
    }

    var vtype = $('#promo-visual-type').val();
    $('#promo-banner-settings').hide();
    if (vtype == 'banner') {
        $('#promo-banner-settings').show();
    } else if (vtype == 'product_slider') {
        $('#promo-scope').val('specific_products').change();
        $('#promo-scope').closest('.form-group').hide();
    }
}

function togglePromoScope() {
    var scope = $('#promo-scope').val();
    $('#promo-scope-products, #promo-scope-categories').hide();
    if(scope == 'specific_products') $('#promo-scope-products').show();
    if(scope == 'specific_categories') $('#promo-scope-categories').show();
}


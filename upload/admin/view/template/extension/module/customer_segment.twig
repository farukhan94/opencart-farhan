function openComboModal(combo_id) {
    $('#form-combo')[0].reset();
    $('#combo-group-list').empty();
    $('#combo-product-list').empty();
    $('#combo-product-ids').val('');
    $('#combo-id').val(combo_id || '');

    if (combo_id) {
        $.ajax({
            url: 'index.php?route=extension/module/customer_segment/getCombos&user_token={{ user_token }}',
            dataType: 'json',
            success: function(json) {
                var c = json.find(x => x.combo_id == combo_id);
                if (c) {
                    $('#combo-name').val(c.name);
                    $('#combo-discount-value').val(c.discount_value);
                    $('#combo-discount-type').val(c.discount_type);
                    $('#combo-discount-mode').val(c.discount_mode);
                    $('#combo-status').val(c.status);
                    var comboGroupMap = c.group_map || {};
                    if (c.group_ids) {
                        $.each(c.group_ids, function(_, groupId) {
                            var gid = parseInt(groupId, 10);
                            var groupName = comboGroupMap[gid] || ('Group #' + gid);
                            $('#combo-group-list').append('<div id="combo-group-list-item' + gid + '"><i class="fa fa-minus-circle"></i> ' + groupName + '<input type="hidden" name="group_ids[]" value="' + gid + '" /></div>');
                        });
                    }

                    var productIdList = [];
                    if (Array.isArray(c.product_id_list)) {
                        productIdList = c.product_id_list;
                    } else if (c.product_ids) {
                        productIdList = String(c.product_ids).split(',').map(function(id) { return parseInt(id, 10); }).filter(function(id) { return id > 0; });
                    }

                    if (productIdList.length) {
                        $('#combo-product-ids').val(productIdList.join(','));
                        $.ajax({
                            url: 'index.php?route=extension/module/customer_segment/getProductInfo&user_token={{ user_token }}&ids=' + productIdList.join(','),
                            dataType: 'json',
                            success: function(pJson) {
                                pJson.forEach(function(p) {
                                    var pid = parseInt(p.product_id, 10);
                                    $('#combo-product-list').append('<div id="combo-product-item' + pid + '"><i class="fa fa-minus-circle"></i> ' + p.name + '<input type="hidden" name="product_ids[]" value="' + pid + '" /></div>');
                                });
                                syncComboProductIds();
                            }
                        });
                    }
                }
            }
        });
    }
    $('#modal-combo').modal('show');
}

function saveCombo() {
    syncComboProductIds();
    $.ajax({
        url: 'index.php?route=extension/module/customer_segment/saveCombo&user_token={{ user_token }}',
        type: 'post', data: $('#form-combo').serialize(), dataType: 'json',
        success: function(json) {
            if (json.error) { alert(json.error); } else { $('#modal-combo').modal('hide'); loadCombos(); }
        }
    });
}

function deleteCombo(id) {
    if (confirm('Delete this combo?')) {
        $.ajax({ url: 'index.php?route=extension/module/customer_segment/deleteCombo&user_token={{ user_token }}&combo_id=' + id, dataType: 'json', success: function() { loadCombos(); } });
    }
}

$('#combo-product-search').autocomplete({
    'source': function(request, response) {
        $.ajax({
            url: 'index.php?route=catalog/product/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
            dataType: 'json',
            success: function(json) { response($.map(json, function(item) { return { label: item['name'], value: item['product_id'] } })); }
        });
    },
    'select': function(item) {
        $('#combo-product-search').val('');
        var productId = parseInt(item['value'], 10);

        if (!$('#combo-product-item' + productId).length) {
            $('#combo-product-list').append('<div id="combo-product-item' + productId + '"><i class="fa fa-minus-circle"></i> ' + item['label'] + '<input type="hidden" name="product_ids[]" value="' + productId + '" /></div>');
        }
        syncComboProductIds();
    }
});

function syncComboProductIds() {
    var selectedIds = [];
    $('#combo-product-list input[name=\'product_ids[]\']').each(function() {
        selectedIds.push($(this).val());
    });
    $('#combo-product-ids').val(selectedIds.join(','));
}

$('#combo-product-list').delegate('.fa-minus-circle', 'click', function() {
    $(this).parent().remove();
    syncComboProductIds();
});


    var product_ids = [];
    $('#promo-product-list input[name="selected_product[]"]').each(function() { product_ids.push($(this).val()); });
    $('#promo-product-ids').val(product_ids.join(','));

    var category_ids = [];
    $('#promo-category-list input[name="category_ids[]"]').each(function() { category_ids.push($(this).val()); });
